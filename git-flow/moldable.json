{
  "name": "Git",
  "version": "0.1.17",
  "aliases": ["repo", "version-control"],
  "visibility": "public",
  "description": "Simple Git client for branch management, staging, and diffing",
  "runtime": "vite_hono",
  "author": "Moldable",
  "license": "FSL-1.1-ALv2",
  "repository": "moldable-ai/apps",
  "icon": "🛠️",
  "iconPath": "public/icon.png",
  "routeName": "git-flow",
  "category": "developer-tools",
  "tags": ["git", "version-control", "developer", "code"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.19",
    "@moldable-ai/storage": "^0.1.6"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "git.repository",
        "name": "Git repository",
        "description": "Read Git repository status, diffs, history, recent repositories, and non-destructive AI helpers.",
        "scopes": [
          {
            "id": "git.status",
            "name": "Git status",
            "description": "Get repository branch, changed files, unpushed commits, and recent repositories.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "repoPath": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "git.repos.list",
            "name": "Recent repositories",
            "description": "List recent repositories tracked by the Git app."
          },
          {
            "id": "git.repo.set",
            "name": "Set current repository",
            "description": "Set the Git app current repository.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                }
              },
              "required": ["path"]
            }
          },
          {
            "id": "git.repo.remove",
            "name": "Remove tracked repository",
            "description": "Forget a repository in the active workspace without deleting or modifying its files.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                }
              },
              "required": ["path"]
            }
          },
          {
            "id": "git.diff",
            "name": "Current diff",
            "description": "Get the current staged and unstaged diff, optionally for one file.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "repoPath": {
                  "type": "string"
                },
                "filePath": {
                  "type": "string"
                },
                "maxChars": {
                  "type": "number"
                }
              }
            }
          },
          {
            "id": "git.commitDiff",
            "name": "Commit diff",
            "description": "Get the diff for one commit hash.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "hash": {
                  "type": "string"
                },
                "repoPath": {
                  "type": "string"
                },
                "maxChars": {
                  "type": "number"
                }
              },
              "required": ["hash"]
            }
          },
          {
            "id": "git.history",
            "name": "Commit history",
            "description": "List recent commits.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "repoPath": {
                  "type": "string"
                },
                "limit": {
                  "type": "number"
                }
              }
            }
          },
          {
            "id": "git.generateCommitMessage",
            "name": "Generate commit message",
            "description": "Generate a commit summary and body for selected changed files.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["paths"]
            }
          },
          {
            "id": "git.reviewCode",
            "name": "Review selected diff",
            "description": "Review selected changed files and return actionable findings.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["paths"]
            }
          },
          {
            "id": "git.editors.list",
            "name": "Detected editors",
            "description": "List editors detected by the Git app."
          }
        ]
      }
    ]
  },
  "env": [],
  "screenshots": ["public/screenshots/1.png"],
  "tagline": "A clean Git client with AI commits and review, built in"
}
