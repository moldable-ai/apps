{
  "name": "Code",
  "version": "0.1.6",
  "aliases": ["editor", "ide"],
  "visibility": "public",
  "description": "A lightweight, VS Code-like IDE for exploring and editing local codebases with integrated AI context and browser preview.",
  "runtime": "vite_hono",
  "author": "Moldable",
  "license": "FSL-1.1-ALv2",
  "icon": "💻",
  "iconPath": "public/icon.png",
  "category": "developer-tools",
  "tags": [],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.13",
    "@moldable-ai/storage": "^0.1.5"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "code.project",
        "name": "Code project",
        "description": "Read and update Code app project context and inspect files through the Code app.",
        "scopes": [
          {
            "id": "code.project.get",
            "name": "Get current project",
            "description": "Get the current root path, preview URL, recent projects, and open tabs."
          },
          {
            "id": "code.project.recent",
            "name": "Recent projects",
            "description": "List recently opened projects."
          },
          {
            "id": "code.project.set",
            "name": "Set current project",
            "description": "Set the current project root and optional preview URL.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "rootPath": {
                  "type": "string"
                },
                "previewUrl": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "code.preferences.get",
            "name": "Get Code preferences",
            "description": "Read Code app workspace preferences."
          },
          {
            "id": "code.files.search",
            "name": "Search project files",
            "description": "Search files in the current or supplied project root, respecting .gitignore.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "root": {
                  "type": "string"
                },
                "pattern": {
                  "type": "string",
                  "description": "fast-glob pattern. Defaults to **/*."
                },
                "query": {
                  "type": "string"
                },
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 500
                }
              }
            }
          },
          {
            "id": "code.files.list",
            "name": "List directory",
            "description": "List files and folders under a directory, including ignore-dim state.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "root": {
                  "type": "string"
                },
                "includeHidden": {
                  "type": "boolean"
                }
              },
              "required": ["path"]
            }
          },
          {
            "id": "code.files.read",
            "name": "Read file",
            "description": "Read a text file through the Code app.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "maxChars": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 100000
                }
              },
              "required": ["path"]
            }
          }
        ]
      }
    ]
  },
