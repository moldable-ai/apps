{
  "name": "Calendar",
  "version": "0.1.2",
  "runtime": "vite_hono",
  "visibility": "public",
  "description": "Integrated calendar with Google Calendar connection",
  "author": "Moldable Team",
  "license": "FSL-1.1-ALv2",
  "repository": "moldable-ai/apps",
  "icon": "🗓️",
  "iconPath": "public/icon.svg",
  "widgetSize": "medium",
  "widgetTint": "blue",
  "category": "productivity",
  "tags": ["calendar", "schedule", "events", "google"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.6",
    "@moldable-ai/storage": "^0.1.3"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "calendar.events",
        "name": "Calendar events",
        "description": "Allow approved apps to read calendar events in this workspace.",
        "scopes": [
          {
            "id": "events.today",
            "name": "Today's calendar events",
            "description": "See event titles, times, and availability for today's schedule in this workspace.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "onlyFuture": {
                  "type": "boolean"
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "events.upcoming",
            "name": "Upcoming calendar events",
            "description": "See upcoming events over the next N days.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "days": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 90
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                }
              }
            }
          },
          {
            "id": "events.list",
            "name": "Calendar events in a date range",
            "description": "See event titles, start and end times, and availability for a requested date range so the app can show upcoming schedule context.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "timeMin": {
                  "type": "string",
                  "description": "ISO datetime lower bound."
                },
                "timeMax": {
                  "type": "string",
                  "description": "ISO datetime upper bound."
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "events.search",
            "name": "Search calendar events",
            "description": "Search calendar event title, location, and status within an optional date range.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "timeMin": {
                  "type": "string"
                },
                "timeMax": {
                  "type": "string"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                }
              }
            }
          },
          {
            "id": "events.get",
            "name": "Get calendar event",
            "description": "Get one calendar event by ID from the default event window.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "calendar.status",
            "name": "Calendar connection status",
            "description": "Check whether Calendar is connected in this workspace."
          },
          {
            "id": "calendars.list",
            "name": "List calendars",
            "description": "List Google calendars available to the connected account."
          }
        ]
      }
    ]
  },
  "env": [],
  "upstream": {
    "repo": "moldable-ai/apps",
    "path": "calendar",
    "installedVersion": "0.1.0",
    "installedCommit": "79c470e37f19631020babbc35646d6ef4eb515fa",
    "installedAt": "2026-01-15T03:56:56Z"
  },
  "modified": false,
  "routeName": "calendar"
}
