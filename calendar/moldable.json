{
  "name": "Calendar",
  "version": "0.1.8",
  "aliases": ["schedule", "events"],
  "runtime": "vite_hono",
  "visibility": "public",
  "description": "Integrated calendar with Google Calendar connection",
  "author": "Moldable",
  "license": "FSL-1.1-ALv2",
  "repository": "moldable-ai/apps",
  "icon": "🗓️",
  "iconPath": "public/icon.png",
  "category": "productivity",
  "tags": ["calendar", "schedule", "events", "google"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.13",
    "@moldable-ai/storage": "^0.1.5"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "calendar.events",
        "name": "Calendar events",
        "description": "Allow approved apps to read calendar events in this workspace.",
        "scopes": [
          {
            "id": "events.today",
            "name": "Today's calendar events",
            "description": "See event titles, times, attendees, organizers, conferencing links, and availability for today's schedule in this workspace.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "onlyFuture": {
                  "type": "boolean"
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "events.upcoming",
            "name": "Upcoming calendar events",
            "description": "See upcoming event titles, times, attendees, organizers, conferencing links, and availability over the next N days.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "days": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 90
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                }
              }
            }
          },
          {
            "id": "events.list",
            "name": "Calendar events in a date range",
            "description": "See event titles, start and end times, attendees, organizers, conferencing links, and availability for a requested date range so the app can show schedule context.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "timeMin": {
                  "type": "string",
                  "description": "ISO datetime lower bound."
                },
                "timeMax": {
                  "type": "string",
                  "description": "ISO datetime upper bound."
                },
                "includeDeclined": {
                  "type": "boolean"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                },
                "query": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "events.search",
            "name": "Search calendar events",
            "description": "Search calendar event title, location, attendees, organizer, conferencing links, and status within an optional date range.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "timeMin": {
                  "type": "string"
                },
                "timeMax": {
                  "type": "string"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 2500
                }
              }
            }
          },
          {
            "id": "events.get",
            "name": "Get calendar event",
            "description": "Get one calendar event by ID from the default event window.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "events.findByICalUid",
            "name": "Find event by iCalendar UID",
            "description": "Find a Google Calendar event by its iCalendar UID and return the current attendee response status.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "iCalUid": {
                  "type": "string"
                }
              },
              "required": ["iCalUid"]
            }
          },
          {
            "id": "events.rsvp",
            "name": "Respond to calendar invite",
            "description": "Update the current user's RSVP status for an existing Google Calendar event.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "eventId": {
                  "type": "string"
                },
                "iCalUid": {
                  "type": "string"
                },
                "responseStatus": {
                  "type": "string",
                  "enum": ["accepted", "tentative", "declined", "needsAction"]
                },
                "sendUpdates": {
                  "type": "string",
                  "enum": ["all", "externalOnly", "none"]
                }
              },
              "required": ["responseStatus"]
            }
          },
          {
            "id": "calendar.status",
            "name": "Calendar connection status",
            "description": "Check whether Calendar is connected in this workspace."
          },
          {
            "id": "calendars.list",
            "name": "List calendars",
            "description": "List Google calendars available to the connected account."
          }
        ]
      }
    ]
  },
