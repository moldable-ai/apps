{
  "name": "Translate",
  "version": "0.1.6",
  "aliases": [
    "translation",
    "translator"
  ],
  "visibility": "public",
  "description": "Fast, private text translation across dozens of languages",
  "runtime": "vite_hono",
  "author": "Moldable",
  "license": "FSL-1.1-ALv2",
  "repository": "moldable-ai/apps",
  "icon": "🌐",
  "iconPath": "public/icon.png",
  "category": "productivity",
  "tags": [
    "translate",
    "translation",
    "languages",
    "essentials"
  ],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.18",
    "@moldable-ai/storage": "^0.1.6"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "translate.text",
        "name": "Text translation",
        "description": "Translate text between languages and read recent translations.",
        "scopes": [
          {
            "id": "translate.text",
            "name": "Translate text",
            "description": "Translate a piece of text into a target language, optionally auto-detecting the source.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "from": {
                  "type": "string",
                  "description": "Source language code, or \"auto\" to detect."
                },
                "to": {
                  "type": "string",
                  "description": "Target language code."
                }
              },
              "required": [
                "text",
                "to"
              ]
            }
          },
          {
            "id": "translate.detect",
            "name": "Detect language",
            "description": "Detect the language of a piece of text.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                }
              },
              "required": [
                "text"
              ]
            }
          },
          {
            "id": "translate.history.list",
            "name": "List recent translations",
            "description": "List the most recent text translations made in this workspace.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 100
                }
              }
            }
          }
        ]
      }
    ]
  },
  "env": [],
  "vault": [
    {
      "key": "DEEPL_API_KEY",
      "name": "DeepL API Key",
      "description": "Powers automatic text translation between languages",
      "url": "https://www.deepl.com/en/your-account/keys",
      "required": true,
      "capabilities": [
        "deepl/translate"
      ]
    }
  ],
  "routeName": "translate",
  "tagline": "Translate anything, privately"
}
