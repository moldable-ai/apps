{
  "name": "Scribo Languages",
  "version": "0.1.13",
  "aliases": ["translation", "languages"],
  "visibility": "public",
  "description": "Language learning journal with AI-powered translations",
  "runtime": "vite_hono",
  "author": "Moldable",
  "license": "FSL-1.1-ALv2",
  "repository": "moldable-ai/apps",
  "icon": "📓",
  "iconPath": "public/icon.png",
  "category": "education",
  "tags": ["languages", "translation", "learning", "journal"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.19",
    "@moldable-ai/editor": "^0.1.18",
    "@moldable-ai/storage": "^0.1.6"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "scribo.entries",
        "name": "Language journal entries",
        "description": "Read and manage Scribo language journal entries and translations.",
        "scopes": [
          {
            "id": "scribo.entries.list",
            "name": "List entries",
            "description": "List journal entries with optional language and text filters.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "sourceLanguage": {
                  "type": "string"
                },
                "targetLanguage": {
                  "type": "string"
                },
                "includeTranslation": {
                  "type": "boolean"
                },
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 200
                }
              }
            }
          },
          {
            "id": "scribo.entries.search",
            "name": "Search entries",
            "description": "Search entry title, source text, and translation.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "includeTranslation": {
                  "type": "boolean"
                },
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 200
                }
              }
            }
          },
          {
            "id": "scribo.entries.get",
            "name": "Get entry",
            "description": "Get one journal entry by ID.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "scribo.entries.create",
            "name": "Create entry",
            "description": "Create a language journal entry.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "translation": {
                  "type": "string"
                },
                "sourceLanguage": {
                  "type": "string"
                },
                "targetLanguage": {
                  "type": "string"
                }
              }
            }
          },
          {
            "id": "scribo.entries.update",
            "name": "Update entry",
            "description": "Update journal entry title, content, translation, or language pair.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "translation": {
                  "type": "string"
                },
                "sourceLanguage": {
                  "type": "string"
                },
                "targetLanguage": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "scribo.entries.delete",
            "name": "Delete entry",
            "description": "Delete one journal entry.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "scribo.translate",
            "name": "Translate markdown",
            "description": "Translate markdown text using Scribo's translation provider and block cache.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "markdown": {
                  "type": "string"
                },
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "cache": {
                  "type": ["object", "null"],
                  "description": "Optional Scribo translation cache."
                }
              },
              "required": ["markdown", "from", "to"]
            }
          }
        ]
      }
    ]
  },
  "env": [],
  "vault": [
    {
      "key": "DEEPL_API_KEY",
      "name": "DeepL API Key",
      "description": "Powers automatic translations between languages",
      "url": "https://www.deepl.com/en/your-account/keys",
      "required": true,
      "capabilities": ["deepl/translate"]
    },
    {
      "key": "ELEVENLABS_API_KEY",
      "name": "ElevenLabs API Key",
      "description": "Powers text-to-speech pronunciation playback",
      "url": "https://elevenlabs.io/app/settings/api-keys",
      "required": false,
      "capabilities": ["elevenlabs/text-to-speech"]
    }
  ],
