{
  "name": "scribo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/moldable-dev.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .vite"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.30.0",
    "@lexical/code": "^0.39.0",
    "@lexical/extension": "^0.39.0",
    "@lexical/headless": "^0.39.0",
    "@lexical/link": "^0.39.0",
    "@lexical/list": "^0.39.0",
    "@lexical/markdown": "^0.39.0",
    "@lexical/rich-text": "^0.39.0",
    "@moldable-ai/editor": "^0.1.7",
    "@moldable-ai/storage": "^0.1.4",
    "@moldable-ai/ui": "^0.2.7",
    "@tanstack/react-query": "^5.99.2",
    "@vitejs/plugin-react": "^6.0.1",
    "hono": "^4.12.14",
    "lexical": "^0.39.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vite": "^8.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@moldable-ai/eslint-config": "0.1.4",
    "@moldable-ai/typescript-config": "0.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
