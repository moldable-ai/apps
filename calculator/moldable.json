{
  "aliases": [
    "calc",
    "convert",
    "converter"
  ],
  "appApi": {
    "capabilities": [
      {
        "description": "Allow approved apps to evaluate math expressions and convert units or currency using Calculator.",
        "id": "calculator.compute",
        "name": "Calculator compute",
        "scopes": [
          {
            "description": "Evaluate an arithmetic or scientific math expression and return the numeric result. Records the calculation to history.",
            "id": "compute.evaluate",
            "inputSchema": {
              "properties": {
                "angleMode": {
                  "description": "Angle unit for trigonometric functions. Defaults to deg.",
                  "enum": [
                    "deg",
                    "rad"
                  ],
                  "type": "string"
                },
                "expression": {
                  "description": "Math expression, e.g. \"2 * (3 + 4)\" or \"sin(45) + sqrt(2)\".",
                  "type": "string"
                },
                "record": {
                  "description": "Whether to save this calculation to history. Defaults to true.",
                  "type": "boolean"
                }
              },
              "required": [
                "expression"
              ],
              "type": "object"
            },
            "name": "Evaluate an expression"
          },
          {
            "description": "Convert a value between units in a category (length, mass, temperature, volume, area, speed, data, time) or between currencies.",
            "id": "convert.units",
            "inputSchema": {
              "properties": {
                "category": {
                  "description": "Optional conversion category. Inferred from the units when omitted.",
                  "enum": [
                    "length",
                    "mass",
                    "temperature",
                    "volume",
                    "area",
                    "speed",
                    "data",
                    "time",
                    "currency"
                  ],
                  "type": "string"
                },
                "from": {
                  "description": "Source unit/currency code, e.g. \"km\" or \"USD\".",
                  "type": "string"
                },
                "record": {
                  "description": "Whether to save this conversion to history. Defaults to true.",
                  "type": "boolean"
                },
                "to": {
                  "description": "Target unit/currency code, e.g. \"mi\" or \"EUR\".",
                  "type": "string"
                },
                "value": {
                  "type": "number"
                }
              },
              "required": [
                "value",
                "from",
                "to"
              ],
              "type": "object"
            },
            "name": "Convert units or currency"
          }
        ]
      },
      {
        "description": "Allow approved apps to read and search past calculations in this workspace.",
        "id": "calculator.history",
        "name": "Calculator history",
        "scopes": [
          {
            "description": "Read the most recent calculations and conversions for this workspace.",
            "id": "history.recent",
            "inputSchema": {
              "properties": {
                "limit": {
                  "maximum": 500,
                  "minimum": 1,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "Recent calculations"
          },
          {
            "description": "Search past calculations and conversions by expression or result.",
            "id": "history.search",
            "inputSchema": {
              "properties": {
                "limit": {
                  "maximum": 500,
                  "minimum": 1,
                  "type": "number"
                },
                "query": {
                  "type": "string"
                }
              },
              "required": [
                "query"
              ],
              "type": "object"
            },
            "name": "Search calculations"
          },
          {
            "description": "Delete all saved calculations and conversions for this workspace.",
            "id": "history.clear",
            "inputSchema": {
              "properties": {},
              "type": "object"
            },
            "name": "Clear calculation history"
          }
        ]
      }
    ],
    "version": 1
  },
