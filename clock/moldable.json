{
  "aliases": ["alarms", "timer", "stopwatch", "world clock"],
  "appApi": {
    "capabilities": [
      {
        "description": "Allow approved apps to read and control countdown timers in this workspace.",
        "id": "clock.timers",
        "name": "Timers",
        "scopes": [
          {
            "description": "List all timers with their label, duration, run state, and remaining time.",
            "id": "timers.list",
            "inputSchema": {
              "properties": {
                "state": {
                  "enum": ["running", "paused", "idle", "finished"],
                  "type": "string"
                }
              },
              "type": "object"
            },
            "name": "List timers"
          },
          {
            "description": "Create a countdown timer of a given duration and optionally start it.",
            "id": "timers.create",
            "inputSchema": {
              "properties": {
                "durationMs": {
                  "minimum": 1000,
                  "type": "number"
                },
                "label": {
                  "type": "string"
                },
                "start": {
                  "type": "boolean"
                }
              },
              "required": ["durationMs"],
              "type": "object"
            },
            "name": "Create timer"
          },
          {
            "description": "Start or resume a timer by id.",
            "id": "timers.start",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Start timer"
          },
          {
            "description": "Pause a running timer by id.",
            "id": "timers.pause",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Pause timer"
          },
          {
            "description": "Reset a timer back to its full duration. Also dismisses a finished timer.",
            "id": "timers.reset",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Reset timer"
          },
          {
            "description": "Delete a timer by id.",
            "id": "timers.delete",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Delete timer"
          }
        ]
      },
      {
        "description": "Allow approved apps to read and manage alarms in this workspace.",
        "id": "clock.alarms",
        "name": "Alarms",
        "scopes": [
          {
            "description": "List all alarms with their time, label, repeat days, and enabled state.",
            "id": "alarms.list",
            "inputSchema": {
              "properties": {
                "enabledOnly": {
                  "type": "boolean"
                }
              },
              "type": "object"
            },
            "name": "List alarms"
          },
          {
            "description": "Get the next alarm that will fire and how long until it does.",
            "id": "alarms.next",
            "inputSchema": {
              "properties": {},
              "type": "object"
            },
            "name": "Next alarm"
          },
          {
            "description": "Create an alarm for a time of day with optional repeat days.",
            "id": "alarms.create",
            "inputSchema": {
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "label": {
                  "type": "string"
                },
                "repeat": {
                  "items": {
                    "maximum": 6,
                    "minimum": 0,
                    "type": "number"
                  },
                  "type": "array"
                },
                "time": {
                  "description": "24h HH:mm",
                  "type": "string"
                }
              },
              "required": ["time"],
              "type": "object"
            },
            "name": "Create alarm"
          },
          {
            "description": "Update an alarm's time, label, repeat days, or enabled state.",
            "id": "alarms.update",
            "inputSchema": {
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "repeat": {
                  "items": {
                    "maximum": 6,
                    "minimum": 0,
                    "type": "number"
                  },
                  "type": "array"
                },
                "time": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Update alarm"
          },
          {
            "description": "Delete an alarm by id.",
            "id": "alarms.delete",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Delete alarm"
          }
        ]
      },
      {
        "description": "Allow approved apps to read saved world clocks and the current time in each.",
        "id": "clock.worldclocks",
        "name": "World clocks",
        "scopes": [
          {
            "description": "List saved world clocks with their current local time and UTC offset.",
            "id": "worldclocks.list",
            "inputSchema": {
              "properties": {},
              "type": "object"
            },
            "name": "List world clocks"
          }
        ]
      }
    ],
    "version": 1
  },
