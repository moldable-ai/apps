{
  "name": "Images",
  "version": "0.1.0",
  "aliases": ["image generation", "pictures", "art"],
  "runtime": "vite_hono",
  "visibility": "public",
  "description": "Generate and iterate images with GPT Image 2",
  "author": "Moldable",
  "license": "MIT",
  "icon": "🖼️",
  "iconPath": "public/icon.png",
  "widgetSize": "medium",
  "widgetTint": "teal",
  "category": "graphics-design",
  "tags": ["images", "generation", "openai", "gpt-image-2"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.12",
    "@moldable-ai/storage": "^0.1.5"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "images.images",
        "name": "Images",
        "description": "Generate, edit, inspect, and manage GPT Image 2 image threads in the active workspace.",
        "scopes": [
          {
            "id": "images.list",
            "name": "List images",
            "description": "List image threads with their latest iteration metadata.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 100
                }
              }
            }
          },
          {
            "id": "images.get",
            "name": "Get image thread",
            "description": "Get one image thread including all iteration metadata.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "images.generate",
            "name": "Generate image",
            "description": "Generate a new image thread using gpt-image-2.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["prompt"]
            }
          },
          {
            "id": "images.retry",
            "name": "Retry image",
            "description": "Retry a failed new image generation thread with its original prompt and aspect ratio.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "images.cancel",
            "name": "Cancel pending image work",
            "description": "Cancel and clear a pending generation or edit for an image thread. Pending edits keep the last completed image; empty pending generation threads are deleted by default.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "deleteEmptyThread": {
                  "type": "boolean",
                  "description": "When true or omitted, delete a pending generation thread that has no completed iterations. When false, keep it as failed."
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "images.deleteThread",
            "name": "Delete image thread",
            "description": "Delete an image thread and all image files owned by that thread in the active workspace.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "images.deleteIteration",
            "name": "Delete image iteration",
            "description": "Delete one or more image iterations from a thread. If all images are deleted, the thread is deleted too.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "iterationId": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1,
                  "description": "Array of iteration IDs to delete from the thread."
                }
              },
              "required": ["id", "iterationId"]
            }
          },
          {
            "id": "images.edit",
            "name": "Edit image",
            "description": "Create a new iteration in an image thread using gpt-image-2 image edits.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "baseIterationId": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id", "prompt"]
            }
          },
          {
            "id": "images.generateFromReference",
            "name": "Generate from reference",
            "description": "Use an existing image iteration as visual reference while adding a distinct new root image to the same image thread.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "baseIterationId": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id", "prompt"]
            }
          },
          {
            "id": "images.importGenerated",
            "name": "Save generated image",
            "description": "Copy a locally generated image file into an existing image thread or create a new image thread when no id is provided.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Existing image thread id. Omit to create a new thread."
                },
                "imagePath": {
                  "type": "string",
                  "description": "Absolute local path to the image file to save."
                },
                "prompt": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["imagePath"]
            }
          },
          {
            "id": "images.setAspectRatio",
            "name": "Set aspect ratio",
            "description": "Regenerate the selected thread as a new iteration with a different aspect ratio.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                }
              },
              "required": ["id", "aspectRatio"]
            }
          },
          {
            "id": "images.removeBackground",
            "name": "Remove background",
            "description": "Remove the background from an image iteration using remove.bg and save the transparent PNG as a new iteration in the same image thread.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "iterationId": {
                  "type": "string",
                  "description": "Existing iteration id to process. Omit to process the thread's displayed image."
                }
              },
              "required": ["id"]
            }
          }
        ]
      }
    ]
  },
  "env": [],
  "vault": [
    {
      "key": "OPENAI_API_KEY",
      "name": "OpenAI API Key",
      "description": "Fallback for GPT Image 2 generation and image edits when Codex CLI auth is unavailable.",
      "url": "https://platform.openai.com/api-keys",
      "required": true,
      "capabilities": ["openai/image-generation"]
    },
    {
      "key": "REMOVE_BG_API_KEY",
      "name": "Remove.bg API Key",
      "description": "Optional. Enables one-click background removal for the current image.",
      "url": "https://www.remove.bg/api",
      "required": false,
      "capabilities": ["remove-bg/background-removal"]
    }
  ],
  "routeName": "images",
  "tagline": "Generate, edit, and branch images with GPT Image 2"
}
