{
  "name": "Mail",
  "version": "0.2.0",
  "runtime": "vite_hono",
  "visibility": "public",
  "description": "Fast Gmail client for triage, search, reading, and sending email",
  "author": "Moldable Team",
  "license": "FSL-1.1-ALv2",
  "icon": "✉️",
  "widgetSize": "medium",
  "widgetTint": "blue",
  "category": "productivity",
  "tags": ["email", "gmail", "inbox", "productivity"],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.6",
    "@moldable-ai/storage": "^0.1.3"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "email.messages",
        "name": "Email messages",
        "description": "Allow approved apps to read selected Gmail message context in this workspace.",
        "scopes": [
          {
            "id": "mail.status",
            "name": "Email connection status",
            "description": "Check whether Gmail is connected in this workspace."
          },
          {
            "id": "messages.unread",
            "name": "Unread email",
            "description": "List recent unread email summaries.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "labelId": {
                  "type": "string"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 50
                }
              }
            }
          },
          {
            "id": "messages.search",
            "name": "Search email",
            "description": "Search Gmail and return compact message summaries.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "query": {
                  "type": "string"
                },
                "labelId": {
                  "type": "string"
                },
                "maxResults": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 50
                }
              }
            }
          },
          {
            "id": "messages.get",
            "name": "Get email message",
            "description": "Get one Gmail message by ID.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          }
        ]
      }
    ]
  },
  "env": [],
  "routeName": "mail",
  "iconPath": "public/icon.svg"
}
