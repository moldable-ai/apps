{
  "name": "Redecorate",
  "version": "0.1.1",
  "aliases": [
    "interior design",
    "home design",
    "room makeover",
    "redesign",
    "renovation",
    "landscape design"
  ],
  "runtime": "vite_hono",
  "visibility": "private",
  "description": "Reimagine your home, inside and out — a folder-based playground for AI room, exterior, backyard, and floorplan redesigns.",
  "author": "Moldable",
  "license": "MIT",
  "icon": "🛋️",
  "iconPath": "public/icon.png",
  "category": "graphics-design",
  "tags": [
    "interior design",
    "home",
    "redesign",
    "renovation",
    "architecture",
    "landscape",
    "staging",
    "gpt-image-2"
  ],
  "moldableDependencies": {
    "@moldable-ai/ui": "^0.2.13",
    "@moldable-ai/storage": "^0.1.5"
  },
  "appApi": {
    "version": 1,
    "capabilities": [
      {
        "id": "redecorate.redecorate",
        "name": "Redecorate",
        "description": "Create folders, import room/exterior/floorplan photos, generate and remix redesigns, and organize ideas in the active workspace.",
        "scopes": [
          {
            "id": "redecorate.folders.list",
            "name": "List folders",
            "description": "List room/space folders with cover renders and design counts.",
            "inputSchema": {
              "type": "object",
              "properties": {}
            }
          },
          {
            "id": "redecorate.folders.create",
            "name": "Create folder",
            "description": "Create a new folder (e.g. Living Room, Backyard).",
            "inputSchema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "emoji": {
                  "type": "string"
                },
                "space": {
                  "type": "string",
                  "enum": ["interior", "exterior", "both"]
                },
                "blurb": {
                  "type": "string"
                }
              },
              "required": ["name"]
            }
          },
          {
            "id": "redecorate.folders.rename",
            "name": "Rename folder",
            "description": "Rename a folder or change its emoji/blurb.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "emoji": {
                  "type": "string"
                },
                "blurb": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.folders.archive",
            "name": "Delete folder",
            "description": "Delete a folder; its designs return to All designs (unfiled).",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.list",
            "name": "List designs",
            "description": "List designs (spaces) with their latest render. Each design holds the original photo plus its redesign variants.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "limit": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 100
                }
              }
            }
          },
          {
            "id": "redecorate.designs.get",
            "name": "Get design",
            "description": "Get one design including every render/iteration and before/after lineage.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.generate",
            "name": "Generate design",
            "description": "Generate a new design render from a text prompt (optionally into a folder, optionally seeded by a style preset).",
            "inputSchema": {
              "type": "object",
              "properties": {
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                },
                "folderId": {
                  "type": ["string", "null"]
                },
                "presetId": {
                  "type": "string"
                }
              },
              "required": ["prompt"]
            }
          },
          {
            "id": "redecorate.images.import",
            "name": "Import image",
            "description": "Save a room/exterior/floorplan/inspiration image from an absolute local path as a new design, optionally into a folder.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Existing design id. Omit to create a new design."
                },
                "imagePath": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "folderId": {
                  "type": ["string", "null"]
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                }
              },
              "required": ["imagePath"]
            }
          },
          {
            "id": "redecorate.designs.remix",
            "name": "Remix design",
            "description": "Create a new render as a child of an existing render using GPT Image edits — e.g. 'make this living room warmer'. Preserves room geometry.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "baseIterationId": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id", "prompt"]
            }
          },
          {
            "id": "redecorate.designs.generateFromReference",
            "name": "New variant from render",
            "description": "Use an existing render as visual reference while adding a distinct new variant in the same design.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "baseIterationId": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id", "prompt"]
            }
          },
          {
            "id": "redecorate.designs.favorite",
            "name": "Favorite design",
            "description": "Mark a design as a favorite (or unset).",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "favorite": {
                  "type": "boolean"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.archive",
            "name": "Archive design",
            "description": "Archive (or unarchive) a design to hide it without deleting.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "archived": {
                  "type": "boolean"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.move",
            "name": "Move design",
            "description": "Move a design into a folder, or pass null to unfile it.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "folderId": {
                  "type": ["string", "null"]
                }
              },
              "required": ["id", "folderId"]
            }
          },
          {
            "id": "redecorate.designs.delete",
            "name": "Delete design",
            "description": "Delete a design and all of its renders.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.deleteIteration",
            "name": "Delete render",
            "description": "Delete one or more renders from a design. Deleting them all removes the design.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "iterationId": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1
                }
              },
              "required": ["id", "iterationId"]
            }
          },
          {
            "id": "redecorate.designs.retry",
            "name": "Retry render",
            "description": "Retry a failed render with its original prompt.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.cancel",
            "name": "Cancel pending render",
            "description": "Cancel and clear a pending render for a design.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "deleteEmptyThread": {
                  "type": "boolean"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.designs.setAspectRatio",
            "name": "Set aspect ratio",
            "description": "Regenerate the design as a new render with a different aspect ratio.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "baseIterationId": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                }
              },
              "required": ["id", "aspectRatio"]
            }
          },
          {
            "id": "redecorate.designs.importGenerated",
            "name": "Save generated render",
            "description": "Save a locally generated image file into an existing design, or create a new design when no id is given.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "imagePath": {
                  "type": "string"
                },
                "prompt": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "aspectRatio": {
                  "type": "string",
                  "enum": [
                    "square",
                    "portrait",
                    "story",
                    "landscape",
                    "widescreen"
                  ]
                },
                "quality": {
                  "type": "string",
                  "enum": ["low", "medium", "high", "auto"]
                },
                "folderId": {
                  "type": ["string", "null"]
                }
              },
              "required": ["imagePath"]
            }
          },
          {
            "id": "redecorate.designs.removeBackground",
            "name": "Remove background",
            "description": "Remove the background from a render and save the transparent PNG as a new render.",
            "inputSchema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "iterationId": {
                  "type": "string"
                }
              },
              "required": ["id"]
            }
          },
          {
            "id": "redecorate.presets.list",
            "name": "List style presets",
            "description": "List the built-in style presets, prompt templates, and categories.",
            "inputSchema": {
              "type": "object",
              "properties": {}
            }
          }
        ]
      }
    ]
  },
  "env": [],
  "vault": [
    {
      "key": "OPENAI_API_KEY",
      "name": "OpenAI API Key",
      "description": "Powers GPT Image 2 redesigns, remixes, and reference renders when Codex CLI auth is unavailable.",
      "url": "https://platform.openai.com/api-keys",
      "required": true,
      "capabilities": ["openai/image-generation"]
    },
    {
      "key": "REMOVE_BG_API_KEY",
      "name": "Remove.bg API Key",
      "description": "Optional. Enables one-click background removal for a render.",
      "url": "https://www.remove.bg/api",
      "required": false,
      "capabilities": ["remove-bg/background-removal"]
    }
  ],
  "routeName": "redecorate",
  "tagline": "Reimagine every room, facade, and backyard — in one tap",
  "modified": true
}
