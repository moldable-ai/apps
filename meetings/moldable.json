{
  "aliases": ["transcripts", "recording"],
  "appApi": {
    "capabilities": [
      {
        "description": "Allow approved callers to read meeting metadata, notes, summaries, and transcript text in this workspace.",
        "id": "meetings.records",
        "name": "Meeting records",
        "scopes": [
          {
            "description": "List recent meetings with metadata, notes, enhanced notes, and a short transcript preview.",
            "id": "meetings.list",
            "inputSchema": {
              "properties": {
                "includeTranscript": {
                  "description": "Whether to include full transcript text instead of a short preview.",
                  "type": "boolean"
                },
                "limit": {
                  "description": "Maximum number of meetings to return.",
                  "maximum": 100,
                  "minimum": 1,
                  "type": "number"
                }
              },
              "type": "object"
            },
            "name": "List meetings"
          },
          {
            "description": "Search meeting titles, notes, enhanced notes, and transcripts.",
            "id": "meetings.search",
            "inputSchema": {
              "properties": {
                "includeTranscript": {
                  "description": "Whether to include full transcript text for matches.",
                  "type": "boolean"
                },
                "limit": {
                  "description": "Maximum number of matching meetings to return.",
                  "maximum": 100,
                  "minimum": 1,
                  "type": "number"
                },
                "query": {
                  "description": "Search text.",
                  "type": "string"
                }
              },
              "required": ["query"],
              "type": "object"
            },
            "name": "Search meetings"
          },
          {
            "description": "Fetch one meeting by ID, including transcript text.",
            "id": "meetings.get",
            "inputSchema": {
              "properties": {
                "id": {
                  "description": "Meeting ID.",
                  "type": "string"
                },
                "includeTranscript": {
                  "description": "Whether to include transcript text. Defaults to true.",
                  "type": "boolean"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Get meeting"
          },
          {
            "description": "Summarize meeting counts, total duration, transcript coverage, and enhanced notes coverage.",
            "id": "meetings.stats",
            "name": "Meeting stats"
          },
          {
            "description": "Update a meeting title, notes, enhanced notes, or enhanced template id.",
            "id": "meetings.update",
            "inputSchema": {
              "properties": {
                "enhancedNotes": {
                  "type": "string"
                },
                "enhancedTemplateId": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "notes": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Update meeting"
          },
          {
            "description": "Delete a meeting and its saved audio assets.",
            "id": "meetings.delete",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Delete meeting"
          },
          {
            "description": "List built-in and custom enhanced-note templates.",
            "id": "meetings.templates.list",
            "name": "List note templates"
          },
          {
            "description": "Get one enhanced-note template by ID.",
            "id": "meetings.templates.get",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Get note template"
          },
          {
            "description": "Create or update a custom enhanced-note template.",
            "id": "meetings.templates.save",
            "inputSchema": {
              "properties": {
                "context": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "icon": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "sections": {
                  "items": {
                    "properties": {
                      "format": {
                        "enum": ["paragraph", "list"],
                        "type": "string"
                      },
                      "id": {
                        "type": "string"
                      },
                      "length": {
                        "enum": ["concise", "standard", "detailed"],
                        "type": "string"
                      },
                      "prompt": {
                        "type": "string"
                      },
                      "required": {
                        "type": "boolean"
                      },
                      "title": {
                        "type": "string"
                      }
                    },
                    "required": ["id", "title", "prompt"],
                    "type": "object"
                  },
                  "type": "array"
                },
                "writingStyle": {
                  "enum": ["direct", "narrative", "objective"],
                  "type": "string"
                }
              },
              "required": ["id", "name", "sections"],
              "type": "object"
            },
            "name": "Save custom note template"
          },
          {
            "description": "Delete a custom enhanced-note template.",
            "id": "meetings.templates.delete",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Delete custom note template"
          },
          {
            "description": "Read transcription and audio-save settings.",
            "id": "meetings.settings.get",
            "name": "Get meeting settings"
          },
          {
            "description": "Update transcription and audio-save settings.",
            "id": "meetings.settings.update",
            "inputSchema": {
              "properties": {
                "enableDiarization": {
                  "type": "boolean"
                },
                "language": {
                  "type": "string"
                },
                "mipOptOut": {
                  "type": "boolean"
                },
                "model": {
                  "enum": ["nova-3", "nova-3-medical"],
                  "type": "string"
                },
                "saveAudio": {
                  "type": "boolean"
                }
              },
              "type": "object"
            },
            "name": "Update meeting settings"
          },
          {
            "description": "Generate enhanced notes for a meeting, optionally saving them back to the meeting.",
            "id": "meetings.enhanceNotes",
            "inputSchema": {
              "properties": {
                "id": {
                  "type": "string"
                },
                "save": {
                  "type": "boolean"
                },
                "templateId": {
                  "type": "string"
                }
              },
              "required": ["id"],
              "type": "object"
            },
            "name": "Enhance meeting notes"
          }
        ]
      }
    ],
    "version": 1
  },
